# Server
PORT=3001
NODE_ENV=development

# JWT secret — change this to any long random string in production
JWT_SECRET=civictrack-super-secret-key-change-in-prod

# PostgreSQL — update with your local database details
DATABASE_URL=postgresql://postgres:postgres_DB@localhost:5432/civictrack

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
Create civictrack/server/.env.example (safe to commit — no real secrets)
PORT=3001
NODE_ENV=development
JWT_SECRET=your-secret-here
DATABASE_URL=postgresql://postgres:postgres_DB@localhost:5432/civictrack
CLIENT_URL=http://localhost:5173
Create civictrack/.gitignore
node_modules
dist
.env
*.log
.DS_Store
